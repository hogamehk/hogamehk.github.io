# Server
PORT=3000
CORS_ORIGIN=http://127.0.0.1:5500

# OTP behavior
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_LOCK_MINUTES=15
OTP_SIGNING_SECRET=change-this-secret-in-production

# Storage (optional but recommended)
# If empty, server falls back to in-memory store (single instance only)
REDIS_URL=

# SMS provider
# mock | twilio
SMS_PROVIDER=mock
SMS_SENDER=TXUID

# Twilio (required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# Optional alias (same as TWILIO_FROM)
TWILIO_PHONE_NUMBER=

# Development only: return OTP in API response when using mock
EXPOSE_TEST_OTP=true
